"""Traffic sign recognition workflow for YOLOv8.

Usage examples:
  # 1) Train
  python traffic_sign_yolov8.py train \
      --data datasets/traffic_sign/data.yaml \
      --model yolov8n.pt \
      --epochs 100 --imgsz 640

  # 2) Validate
  python traffic_sign_yolov8.py val --weights runs/detect/train/weights/best.pt --data datasets/traffic_sign/data.yaml

  # 3) Predict (image/video/folder)
  python traffic_sign_yolov8.py predict --weights runs/detect/train/weights/best.pt --source demo.jpg --conf 0.35

  # 4) Export ONNX
  python traffic_sign_yolov8.py export --weights runs/detect/train/weights/best.pt --format onnx
"""

from __future__ import annotations

import argparse
from pathlib import Path

from ultralytics import YOLO


def train(args: argparse.Namespace) -> None:
    """Train a YOLOv8 detector on traffic sign data."""
    model = YOLO(args.model)
    model.train(
        data=args.data,
        epochs=args.epochs,
        imgsz=args.imgsz,
        batch=args.batch,
        device=args.device,
        workers=args.workers,
        project=args.project,
        name=args.name,
        patience=args.patience,
        cos_lr=True,
        hsv_h=0.015,
        hsv_s=0.7,
        hsv_v=0.4,
        degrees=8,
        translate=0.1,
        scale=0.4,
        fliplr=0.5,
        mosaic=1.0,
        mixup=0.1,
    )


def validate(args: argparse.Namespace) -> None:
    """Evaluate a trained model."""
    model = YOLO(args.weights)
    metrics = model.val(data=args.data, imgsz=args.imgsz, device=args.device, split=args.split)
    print("\nValidation metrics:")
    print(metrics)


def predict(args: argparse.Namespace) -> None:
    """Run inference and save visualized predictions."""
    model = YOLO(args.weights)
    out_dir = Path(args.project) / args.name
    results = model.predict(
        source=args.source,
        imgsz=args.imgsz,
        conf=args.conf,
        iou=args.iou,
        device=args.device,
        save=True,
        save_txt=args.save_txt,
        save_conf=args.save_conf,
        project=args.project,
        name=args.name,
        stream=False,
    )

    print(f"Predictions saved to: {out_dir.resolve()}")
    print(f"Processed {len(results)} frame(s)/image(s)")


def export_model(args: argparse.Namespace) -> None:
    """Export model for deployment."""
    model = YOLO(args.weights)
    exported_path = model.export(format=args.format, imgsz=args.imgsz, dynamic=args.dynamic, simplify=True)
    print(f"Exported to: {exported_path}")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="YOLOv8 traffic sign recognition helper")
    subparsers = parser.add_subparsers(dest="command", required=True)

    train_parser = subparsers.add_parser("train", help="Train YOLOv8 on traffic signs")
    train_parser.add_argument("--data", type=str, required=True, help="Path to data.yaml")
    train_parser.add_argument("--model", type=str, default="yolov8n.pt", help="Base model or checkpoint")
    train_parser.add_argument("--epochs", type=int, default=100)
    train_parser.add_argument("--imgsz", type=int, default=640)
    train_parser.add_argument("--batch", type=int, default=16)
    train_parser.add_argument("--device", type=str, default="0", help='GPU id, e.g. "0"; use "cpu" for CPU')
    train_parser.add_argument("--workers", type=int, default=8)
    train_parser.add_argument("--project", type=str, default="runs/traffic_sign")
    train_parser.add_argument("--name", type=str, default="train")
    train_parser.add_argument("--patience", type=int, default=30)
    train_parser.set_defaults(func=train)

    val_parser = subparsers.add_parser("val", help="Validate model")
    val_parser.add_argument("--weights", type=str, required=True)
    val_parser.add_argument("--data", type=str, required=True)
    val_parser.add_argument("--imgsz", type=int, default=640)
    val_parser.add_argument("--device", type=str, default="0")
    val_parser.add_argument("--split", type=str, default="val", choices=["train", "val", "test"])
    val_parser.set_defaults(func=validate)

    pred_parser = subparsers.add_parser("predict", help="Run inference")
    pred_parser.add_argument("--weights", type=str, required=True)
    pred_parser.add_argument("--source", type=str, required=True, help="Image/video/folder path or camera index")
    pred_parser.add_argument("--imgsz", type=int, default=640)
    pred_parser.add_argument("--conf", type=float, default=0.35)
    pred_parser.add_argument("--iou", type=float, default=0.5)
    pred_parser.add_argument("--device", type=str, default="0")
    pred_parser.add_argument("--save-txt", action="store_true", help="Save labels to txt")
    pred_parser.add_argument("--save-conf", action="store_true", help="Save confidence in txt")
    pred_parser.add_argument("--project", type=str, default="runs/traffic_sign")
    pred_parser.add_argument("--name", type=str, default="predict")
    pred_parser.set_defaults(func=predict)

    export_parser = subparsers.add_parser("export", help="Export model")
    export_parser.add_argument("--weights", type=str, required=True)
    export_parser.add_argument("--format", type=str, default="onnx", choices=["onnx", "engine", "openvino", "torchscript"])
    export_parser.add_argument("--imgsz", type=int, default=640)
    export_parser.add_argument("--dynamic", action="store_true", help="Enable dynamic shape")
    export_parser.set_defaults(func=export_model)

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
